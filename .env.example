# Copy this file to `.env` and fill in the values for your environment.
# Do NOT commit `.env` — it's git-ignored.

# --- Database -------------------------------------------------------------
# Local development uses a SQLite file at the repo root (`dev.db`).
DATABASE_URL="file:./dev.db"

# --- Auth -----------------------------------------------------------------
# Secret used for cookie/session signing and (future) token HMAC. Generate one
# with: openssl rand -base64 32
# The app refuses to start in production when this is missing, set to a known
# placeholder, or shorter than 32 characters.
AUTH_SECRET="replace-me-with-a-secure-random-value"

# --- Public app URL -------------------------------------------------------
# Absolute URL of the app, used for share-invoice links and email templates.
# Production example: https://invoicloop.example.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
