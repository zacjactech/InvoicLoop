# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets out, commit the example)
.env*
!.env.example

# prisma / database
/prisma/dev.db
/prisma/dev.db-journal
/prisma/*.db
/prisma/*.db-journal
/dev.db
/dev.db-journal
*.db
*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS / tooling
.history/
.cursor/

# project-local scratch / planning notes
/Project Plan/

# ai-tool scratch directories
/.mimocode/
/.mimo/
/.aider*

# auth sessions (local dev browser sessions)
.auth/

# test results / playwright reports
/test-results/
/playwright-report/
/test-results
/playwright-report

# screenshots in public (generated assets)
public/*.png
public/*.jpg
public/*.webp
!public/favicon.ico
!public/dashboard-screenshot.png


# demo video (too large for git)
docs/*.webm
docs/*.mp4
